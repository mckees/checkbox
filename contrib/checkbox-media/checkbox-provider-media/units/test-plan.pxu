id: media-kobuk-plan
unit: test plan
_name: Media test plan for FFmpeg hardware encode and decode
include:
  media_kobuk.*
  media_kobuk_smoke.*
bootstrap_include:
    com.canonical.certification::executable
    com.canonical.certification::snap
    graphics_card
    va
    mediasource

